def format_response(stock):

    return f"""
📊 {stock['ticker']}

🏢 {stock.get('name','N/D')}

💰 Preço: R$ {stock.get('price','N/D')}
📈 Variação: {stock.get('change','N/D')}%
📊 Máxima: {stock.get('high','N/D')}
📉 Mínima: {stock.get('low','N/D')}
📦 Volume: {stock.get('volume','N/D')}

⚠️ Dados em tempo real
"""
